{
    "name": "@perspikapps/klick-deploy",
    "repository": {
        "url": "https://github.com/perspikapps/klick-deploy.git"
    },
    "scripts": {
        "lint": "npx --yes lint-staged",
        "test": "echo \"Warning: no test specified\"",
        "update": "npx --yes npm-check-updates -i -u",
        "update-all": "npm run update -ws --root"
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "prettier": {
        "insertPragma": true,
        "overrides": [
            {
                "files": "*.yml",
                "options": {
                    "useTabs": true,
                    "tabWidth": 2
                }
            }
        ],
        "plugins": [
            "prettier-plugin-sh"
        ],
        "semi": false,
        "singleQuote": true,
        "tabWidth": 4,
        "trailingComma": "es5"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional",
            "@commitlint/config-workspace-scopes"
        ],
        "rules": {
            "subject-case": [
                2,
                "never",
                [
                    "start-case",
                    "pascal-case",
                    "upper-case"
                ]
            ]
        }
    },
    "git-precommit-checks": {
        "rules": [
            {
                "message": "You've got leftover conflict markers",
                "regex": "/^[<>|=]{4,}/m"
            },
            {
                "filter": "(^package\\.json|\\.git-precommit-checks.json)$",
                "message": "You have unfinished devs",
                "nonBlocking": "true",
                "regex": "(?:FIXME|TODO)"
            }
        ]
    },
    "lint-staged": {
        "*.json": [
            "normalize-json -c -w -a -i -f local -l true",
            "npx --yes prettier --write"
        ],
        "*.php": [
            "composer lint"
        ],
        "*.{js,jsx,ts,tsx,md,html,css,vue,yaml,yml}": [
            "npx --yes prettier --write"
        ]
    }
}
